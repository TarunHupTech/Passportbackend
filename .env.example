# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

PORT=5000
NODE_ENV=production

# --- Database ------------------------------------------------------------
# Self-hosted mongod on this same EC2 box, bound to localhost only.
MONGO_URI=mongodb://liali_app:CHANGE_ME@127.0.0.1:27017/liali_prod?authSource=liali_prod

# --- Auth ----------------------------------------------------------------
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# --- URLs ----------------------------------------------------------------
CLIENT_URL=https://club.lialijewellery.com
APP_FRONTEND_URL=https://club.lialijewellery.com

# --- File storage (S3) ---------------------------------------------------
# Required when NODE_ENV=production — the app refuses to boot without them.
# Credentials come from the EC2 instance's IAM role, so NO keys go here.
S3_BUCKET=liali-club-uploads
AWS_REGION=me-central-1

# --- Shopify -------------------------------------------------------------
# App credentials — these belong to the APP, so they stay the same when the
# same app is installed on a different store.
SHOPIFY_API_KEY=cd69c0cc6feec651c4824a0fe556f265
SHOPIFY_API_SECRET=CHANGE_ME_APP_CLIENT_SECRET

# Per-store — these DO change when moving to the client's store.
SHOPIFY_STORE_DOMAIN=client-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=CHANGE_ME_shpat_token_from_client_store
SHOPIFY_ADMIN_API_VERSION=2026-04

# --- Admin portal (seeded on first boot) ---------------------------------
ADMIN_NAME=LIALI Admin
ADMIN_EMAIL=admin@lialijewellery.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
